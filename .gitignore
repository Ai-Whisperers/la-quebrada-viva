# Regenerable Blender state (scene rebuilds from code every headless run)
*.blend
*.blend1
*.blend@
*.blend.lock
scene.blend.session-backup

# Previews are throwaway; finals (renders/<V>_<cam>.png) stay tracked
renders/_preview_*.png
*.exr

# Sub-render driver outputs — regenerable from lqv/subscene/<asset>.py.
# Each is a single-asset preview; not part of the 18-frame final matrix.
renders/sub/
# Browse-friendly symlink tree over renders/sub/, regenerated by
# `python scripts/organize_sub_renders.py`. Symlinks would break in zips anyway.
renders/sub_by_category/

# Wesley deliverable bundle — 271 MB timestamped zip + manifest + sha,
# fully regenerable via `python3 scripts/build_wesley_bundle.py`.
# MUST NOT enter git history (per-file >100 MB limit on the zip).
dist/

__pycache__/
*.pyc
*.bak
*.pre-refactor.bak*
.venv/
.env.local
.env
*.env
.DS_Store
.idea/
.vscode/
.claude/settings.local.json

# Editor swap / backup files (vim, emacs, generic)
*.swp
*.swo
*~
\#*\#
.\#*

# Local-only MCP transport daemon — pinned out of history per project policy.
scripts/mcp_daemon.py

# Crash dumps, runtime logs, transient archives
*.log
*.tmp
*.crdownload
*.part

# Stale artifacts kept out of history (reference-only monolith, old renders).
# Curated doc archive under docs/_archive/ is intentionally tracked (see
# docs/_archive/MANIFEST.md for the index).
_archive/
!docs/_archive/
!docs/_archive/**

# Regenerable assets — re-fetched by scripts/download_assets.sh (HDRIs + PBR
# textures from Poly Haven CC0). assets/models/ is now 16 GB of fetched
# Poly Haven .blend bundles; regenerable via
# `python scripts/download_polyhaven_assets.py`, attribution preserved in
# LICENSES/*.txt stubs. Excluded from the tree to stay under GitHub limits.
assets/hdris/
assets/textures/
assets/models/

# Escritura deck v2 is a 123 MB layout proof that exceeds GitHub's 100 MB
# per-file hard push limit. Kept on disk for stakeholder review; v1, v3-v5
# (each <50 MB) are the versions tracked in history.
docs/escritura_deck/escritura_deck_v2.pdf

# Private legal contract scans (boleto de compraventa, escritura drafts) —
# reproduced with permission of the parties under the carve-out in LICENSE;
# MUST NOT be redistributed via the git history. Protected from accidental
# staging by glob match; share via secure channel only.
docs/*_boleto_*.pdf
docs/*_escritura_*.pdf
docs/2026-*_*.pdf

# Regenerable raw Sentinel-2 raster bands (each ~50-250 MB, over GitHub's
# 100 MB per-file hard limit). Re-fetch with `python scripts/fetch_sentinel2.py`
# from the Element84 / AWS Earth Search STAC. preview_rgb.png + metadata.json
# stay tracked so the AOI/timestamp is reproducible without a re-fetch.
docs/site_data/sentinel2/*.tif
docs/site_data/sentinel2/**/*.tif

# Regenerable Sentinel-1 RTC gamma0 GeoTIFFs (per-scene VV/VH, ~10-30 MB each
# at 302x334 px). Re-fetch via `python3 scripts/phase0_sentinel1_sar_batch.py`
# against Microsoft Planetary Computer's `sentinel-1-rtc`. Quicklook + CSV +
# summary + per-file .meta.json stay tracked.
docs/site_data/sentinel1/*.tif
docs/site_data/sentinel1/**/*.tif

# Regenerable CHIRPS v2.0 monthly rainfall rasters. _cache/ is the global
# 0.05° GeoTIFFs straight from UCSB (~14 GB, 2005-2025). tiles/ is the
# parcel-AOI clip per month (~4 KB x 252 = 1 MB, but still binary churn).
# Both re-fetch via `python3 -m tools.site_data.chirps`. brochure +
# summary stay tracked so the analytic record is preserved.
docs/site_data/chirps/_cache/
docs/site_data/chirps/tiles/

# Regenerable JRC Global Surface Water v1.4 raw 10×10° tiles (~165 MB).
# Re-fetch via `python3 scripts/phase0_jrc_gsw_batch.py`. AOI/polygon clips
# + quicklooks + summary stay tracked.
docs/site_data/jrc_gsw/_cache/

# Regenerable Hansen GFC v1.12 raw 10×10° tiles (~750 MB across 4 layers;
# treecover2000 is the bulk at ~620 MB, lossyear/gain/datamask compress hard.
# `loss` is derived from `lossyear > 0` since v1.12 dropped the standalone band).
# Re-fetch via `python3 scripts/phase0_hansen_gfc_batch.py`. AOI/polygon clips
# + quicklooks + summary stay tracked.
docs/site_data/hansen_gfc/_cache/

# Regenerable Lima et al. 2024 THREAT data tables (Appendices C/D/F + PY/AR
# threat & endemism lists + uses + timber + hotspots, ~5.3 MB total).
# Re-fetch via `python3 scripts/phase0_atlantic_tree_db_batch.py` from
# https://github.com/LimaRAF/THREAT. Derived analytic outputs (master
# checklist + ranked candidates + PY-threatened slice + summary) stay tracked.
docs/site_data/atlantic_forest_trees/_cache/
