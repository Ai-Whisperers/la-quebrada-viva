# Regenerable Blender state (scene rebuilds from code every headless run)
*.blend
*.blend1
*.blend@
*.blend.lock
scene.blend.session-backup

# Previews are throwaway; finals (renders/<V>_<cam>.png) stay tracked
renders/_preview_*.png
*.exr

# Sub-render driver outputs — regenerable from lqv/subscene/<asset>.py.
# Each is a single-asset preview; not part of the 18-frame final matrix.
renders/sub/

__pycache__/
*.pyc
*.bak
*.pre-refactor.bak*
.venv/
.env.local
.env
*.env
.DS_Store
.idea/
.vscode/
.claude/settings.local.json

# Editor swap / backup files (vim, emacs, generic)
*.swp
*.swo
*~
\#*\#
.\#*

# Local-only MCP transport daemon — pinned out of history per project policy.
scripts/mcp_daemon.py

# Crash dumps, runtime logs, transient archives
*.log
*.tmp
*.crdownload
*.part

# Stale artifacts kept out of history (reference-only monolith, old renders)
_archive/

# Regenerable assets — re-fetched by scripts/download_assets.sh (HDRIs + PBR
# textures from Poly Haven CC0). assets/models/ stays tracked.
assets/hdris/
assets/textures/

# Private legal contract scans (boleto de compraventa, escritura drafts) —
# reproduced with permission of the parties under the carve-out in LICENSE;
# MUST NOT be redistributed via the git history. Protected from accidental
# staging by glob match; share via secure channel only.
docs/*_boleto_*.pdf
docs/*_escritura_*.pdf
docs/2026-*_*.pdf

# Regenerable raw Sentinel-2 raster bands (each ~50-250 MB, over GitHub's
# 100 MB per-file hard limit). Re-fetch with `python scripts/fetch_sentinel2.py`
# from the Element84 / AWS Earth Search STAC. preview_rgb.png + metadata.json
# stay tracked so the AOI/timestamp is reproducible without a re-fetch.
docs/site_data/sentinel2/*.tif
